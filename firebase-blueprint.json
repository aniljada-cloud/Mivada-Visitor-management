{
  "entities": {
    "Visitor": {
      "title": "Visitor",
      "description": "A visitor to the workspace.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "Full name of the visitor." },
        "companyName": { "type": "string", "description": "Company the visitor represents." },
        "phone": { "type": "string", "description": "Phone number of the visitor." },
        "email": { "type": "string", "description": "Email address of the visitor." },
        "personToMeet": { "type": "string", "description": "Name of the employee the visitor is meeting." },
        "hostEmail": { "type": "string", "description": "Email address of the employee the visitor is meeting." },
        "hostUid": { "type": "string", "description": "UID of the employee the visitor is meeting." },
        "purpose": { "type": "string", "description": "Purpose of the visit." },
        "photo": { "type": "string", "description": "Base64 encoded photo of the visitor." },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected", "Checked-In", "Checked-Out"], "description": "Current status of the visit." },
        "checkInTime": { "type": "string", "format": "date-time", "description": "Time the visitor checked in." },
        "checkOutTime": { "type": "string", "format": "date-time", "description": "Time the visitor checked out." },
        "preRegistered": { "type": "boolean", "description": "Whether the visitor pre-registered." },
        "qrCodeId": { "type": "string", "description": "Unique ID for the QR code." },
        "rating": { "type": "integer", "description": "Feedback rating from the visitor." },
        "feedback": { "type": "string", "description": "Feedback text from the visitor." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Registration timestamp." }
      },
      "required": ["fullName", "email", "personToMeet", "hostEmail", "status", "createdAt"]
    },
    "Employee": {
      "title": "Employee",
      "description": "An employee of the workspace.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "Full name of the employee." },
        "email": { "type": "string", "description": "Email address of the employee." },
        "role": { "type": "string", "enum": ["admin", "employee", "reception"], "description": "Role of the employee." },
        "department": { "type": "string", "description": "Department of the employee." }
      },
      "required": ["fullName", "email", "role"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings.",
      "type": "object",
      "properties": {
        "smtpHost": { "type": "string", "description": "SMTP server host." },
        "smtpPort": { "type": "integer", "description": "SMTP server port." },
        "smtpUser": { "type": "string", "description": "SMTP server username." },
        "smtpPass": { "type": "string", "description": "SMTP server password." },
        "smtpFrom": { "type": "string", "description": "Sender email address." },
        "smtpSecure": { "type": "boolean", "description": "Whether to use SSL/TLS." }
      }
    }
  },
  "firestore": {
    "/visitors/{visitorId}": {
      "schema": "Visitor",
      "description": "Collection of all visitors."
    },
    "/employees/{employeeId}": {
      "schema": "Employee",
      "description": "Collection of all employees."
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Global settings for the application."
    }
  }
}
